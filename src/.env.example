# Defaults for the robot. main.py loads .env then falls back to this file.

# --- Mode ---------------------------------------------------------------------
# true  -> run as an MCP server (Claude Code drives Pip, no Ollama needed)
# false -> run the local Ollama chat loop in the terminal
ROBOT_MCP=true

# --- Assistant (local Ollama, only used when ROBOT_MCP=false) ------------------
# Install Ollama and pull the model:  ollama pull qwen3.5:4b
ROBOT_MODEL=qwen3.5:4b
OLLAMA_HOST=http://localhost:11434

# --- ESP32 (Bluetooth) --------------------------------------------------------
# Target: empty = auto-pick the first board; or a board name or MAC address.
# Password: must match the firmware's EspBridge.begin("..."); the default
# firmware (EspBridge.begin()) uses "espbridge".
ROBOT_BLE_TARGET=
ROBOT_PASSWORD=espbridge

# --- OLED wiring (128x64 SSD1306 / SH1106) ------------------------------------
ROBOT_OLED_SDA=21
ROBOT_OLED_SCL=22

# --- Animation ----------------------------------------------------------------
ROBOT_FPS=24
